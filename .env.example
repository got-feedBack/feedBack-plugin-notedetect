# Copy to .env and edit. The Makefile auto-loads .env if present; Docker
# Compose also reads it for ${…} substitutions in the overlay.
#
# None of these are required — defaults in the Makefile / slopsmith core will
# kick in if you leave a line commented out. Set the ones that differ from
# your target setup.

# Absolute path to your slopsmith repo. Default: ../slopsmith
#SLOPSMITH_DIR=/home/you/src/slopsmith

# Host port slopsmith binds on (container always listens on 8000 internally).
# Default 8000. Set this if 8000 is taken on your box.
#SLOPSMITH_PORT=8088

# DLC library path slopsmith reads from. Slopsmith's own compose falls back
# to ~/.local/share/Steam/steamapps/common/Rocksmith2014/dlc — set this if
# your CDLC lives elsewhere, e.g. a local test directory.
#DLC_PATH=/home/you/slopsmith-dlc

# Rocksmith USB / audio interface source for `make monitor-on`. Auto-detected
# by default; override if multiple devices confuse the detector.
#MONITOR_SRC=alsa_input.usb-Hercules_Rocksmith_USB_Guitar_Adapter-00.mono-fallback

# Monitor loopback latency in ms (lower = tighter but risks xruns).
#MONITOR_LATENCY_MS=50
